{
  "name": "js-job-search-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Dashboard-first local job-search command center built on reusable CareerOps patterns.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "db:migrate": "tsx scripts/db-migrate.ts",
    "db:seed": "tsx scripts/db-seed.ts",
    "db:reset": "tsx scripts/db-reset.ts",
    "db:check": "tsx scripts/db-check.ts",
    "profile:extract": "tsx scripts/profile-extract.ts",
    "profile:check": "tsx scripts/profile-check.ts"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "clsx": "^2.1.1",
    "next": "^15.3.5",
    "pdf-parse": "^2.4.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.25.0",
    "eslint-config-next": "^15.3.5",
    "postcss": "^8.5.12",
    "tailwindcss": "^3.4.17",
