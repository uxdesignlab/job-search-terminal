{
  "name": "job-search-terminal",
  "version": "0.1.0",
  "description": "A free, source-available, local-first job-search dashboard that helps job seekers scan roles, score fit with AI, generate tailored resumes, track applications, and prepare for interviews without accounts, subscriptions, or cloud storage.",
  "license": "CC-BY-NC-4.0",
  "author": "UX Design Lab",
  "homepage": "https://pavel.ux.business/job-search-terminal/",
  "repository": {
    "type": "git",
    "url": "https://github.com/uxdesignlab/job-search-terminal.git"
  },
  "keywords": [
    "job-search",
    "career",
    "source-available",
    "non-commercial",
    "local-first",
    "ai",
    "resume",
    "applications",
    "nextjs",
    "sqlite"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:migrate": "tsx scripts/db-migrate.ts",
    "db:seed": "tsx scripts/db-seed.ts",
    "db:reset": "tsx scripts/db-reset.ts",
    "db:check": "tsx scripts/db-check.ts",
    "profile:extract": "tsx scripts/profile-extract.ts",
    "profile:check": "tsx scripts/profile-check.ts",
    "scanner:check": "tsx scripts/scanner-check.ts",
    "fresh-matches:check": "tsx scripts/fresh-match-check.ts",
    "evaluation:check": "tsx scripts/evaluation-check.ts",
    "document:check": "tsx scripts/document-check.ts",
    "evidence-audit:check": "tsx scripts/evidence-audit-check.ts",
    "application:check": "tsx scripts/application-check.ts",
    "quality:check": "tsx scripts/quality-check.ts",
    "data:backup": "tsx scripts/data-backup.ts",
    "account:backup": "tsx scripts/account-backup.ts",
    "account:restore": "tsx scripts/account-restore.ts",
    "account:check": "tsx scripts/account-backup-check.ts",
    "data:export": "tsx scripts/data-export.ts",
    "discover:sources": "tsx scripts/discover-sources.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/generative-ai": "^0.24.1",
    "better-sqlite3": "^12.9.0",
    "clsx": "^2.1.1",
    "js-yaml": "^4.1.1",
    "lucide-react": "^1.14.0",
    "next": "15.5.19",
    "openai": "^6.35.0",
    "pdf-parse": "^2.4.5",
    "playwright-core": "^1.59.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "yauzl": "^3.3.1",
    "yazl": "^3.3.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.15.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/yauzl": "^2.10.3",
    "@types/yazl": "^3.3.1",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.25.0",
    "eslint-config-next": "^15.3.5",
    "postcss": "^8.5.12",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "postcss": "$postcss"
  }
}
